 TagBox[GridBox[{
    {"\<\"Operation\"\>", "\<\"Time (s)\"\>"},
    {"\<\"OEISValidateIDQ (pure)\"\>", "0.`"},
    {"\<\"OEISURL, bFile->True (pure)\"\>", "0.0001`"},
    {"\<\"OEISImport, \\\"Description\\\" (network)\"\>", "0.7112`"},
