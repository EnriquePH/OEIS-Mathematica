(* Beginning of Notebook Content *)
Notebook[{
Cell["OEIS Package", "GuideTitle"],

Cell["\<\
Retrieve, export and generate b-files for On-Line Encyclopedia of Integer \
Sequences (OEIS) data through the official JSON API.\
\>", "GuideAbstract"],

Cell["Look up and validate sequences", "GuideFunctionsSubsection"],

Cell["OEISValidateIDQ", "GuideFunction"],

Cell["check that an identifier has the canonical OEIS shape", "GuideText"],

Cell["OEISURL", "GuideFunction"],

Cell["build a sequence or b-file URL", "GuideText"],

Cell["OEISServerURL", "GuideFunction"],

Cell["the base URL used for every OEIS request", "GuideText"],

Cell["OEISTotalNumberOfSequences", "GuideFunction"],

Cell["an estimate of how many sequences OEIS contains", "GuideText"],

Cell["Retrieve sequence data", "GuideFunctionsSubsection"],

Cell["OEISImport", "GuideFunction"],

Cell["\<\
retrieve data, description, author, date or offset for a sequence\
\>", "GuideText"],

Cell["OEISFunction", "GuideFunction"],

Cell["materialize id[n] in your session, preloaded from OEIS", "GuideText"],

Cell["Export and generate files", "GuideFunctionsSubsection"],

Cell["OEISExport", "GuideFunction"],

Cell["\<\
export sequence data or citations to .m, .txt, .bib, .html, .wiki, images\
\>", "GuideText"],

Cell["OEISbFile", "GuideFunction"],

Cell["write a b-file, using a locally defined id[n] when available", \
"GuideText"],

Cell["Tutorials", "RelatedTutorialsSection"],

Cell["OEIS Package: A Tutorial", "RelatedTutorials"]
},
WindowTitle->"OEIS Package",
FrontEndVersion->"11.2 for Linux x86 (64-bit) (September 10, 2017)",
StyleDefinitions->"Guide.nb"
]
(* End of Notebook Content *)

