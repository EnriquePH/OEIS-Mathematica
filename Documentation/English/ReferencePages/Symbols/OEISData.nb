(* Beginning of Notebook Content *)
Notebook[{
Cell["OEISData", "ObjectName"],

Cell["\<\
OEISData[id] returns the full OEIS entry for id as an Association with keys \
\"ID\", \"Description\", \"Author\", \"Date\", \"Offset\", \"Data\" and \
\"Formula\" -- e.g. for Dataset[OEISData[id]].\
\>", "Usage"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection"],

Cell["Keys[OEISData[\"A000045\"]]", "Input"],

Cell["\<\
{\"ID\", \"Description\", \"Author\", \"Date\", \"Offset\", \"Data\", \
\"Formula\"}\
\>", "Output"]
}, Open  ]],

Cell["See Also", "SeeAlsoSection"],

Cell["OEISImport  \[FilledSmallSquare]  OEISSequence", "SeeAlso"]
},
WindowTitle->"OEISData",
TaggingRules->Association["Paclet" -> "OEIS"],
FrontEndVersion->"11.2 for Linux x86 (64-bit) (September 10, 2017)",
