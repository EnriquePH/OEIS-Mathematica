Notebook[{
Cell["OEISSearch", "ObjectName"],

Cell["\<\
OEISSearch[text] searches OEIS by free text. OEISSearch[{n1,n2,...}] searches \
by a sequence of numbers. Both return up to 10 results (OEIS's default page \
size) as a list of Entry Associations.\
\>", "Usage"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection"],

Cell["OEISSearch[\"prime gaps\"][[1]][\"ID\"]", "Input"],

Cell["\"A001223\"", "Output"],

Cell["First[OEISSearch[{1, 1, 2, 3, 5, 8, 13}]][\"ID\"]", "Input"],

Cell["\"A000045\"", "Output"]
}, Open  ]],

Cell["See Also", "SeeAlsoSection"],

Cell["OEISImport  \[FilledSmallSquare]  OEISRelated", "SeeAlso"]
},
WindowTitle->"OEISSearch",
TaggingRules->Association["Paclet" -> "OEIS"],
FrontEndVersion->"11.2 for Linux x86 (64-bit) (September 10, 2017)",
StyleDefinitions->"Reference.nb"
]
