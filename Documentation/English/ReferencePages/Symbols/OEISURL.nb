(* Beginning of Notebook Content *)
Notebook[{
Cell["OEISURL", "ObjectName"],

Cell["\<\
OEISURL[id] gives the OEIS sequence URL for id. OEISURL[id, bFile->True] \
gives the URL of that sequence's b-file instead.\
\>", "Usage"],

Cell["Options", "Subsubsection"],

Cell["\<\
URL -> True
bFile -> False\
\>", "Text"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection"],

Cell["OEISURL[\"A000045\"]", "Input"],

Cell["\"https://oeis.org/A000045\"", "Output"],

Cell["OEISURL[\"A000045\", bFile -> True]", "Input"],

Cell["\"https://oeis.org/b000045.txt\"", "Output"],

Cell["OEISURL[\"A000045\", URL -> False]", "Input"],

Cell["\"A000045\"", "Output"]
}, Open  ]],

Cell["See Also", "SeeAlsoSection"],

Cell["OEISValidateIDQ  \[FilledSmallSquare]  OEISImport  \[FilledSmallSquare] \
 OEISbFile", "SeeAlso"]
},
WindowTitle->"OEISURL",
TaggingRules->Association["Paclet" -> "OEIS"],
FrontEndVersion->"11.2 for Linux x86 (64-bit) (September 10, 2017)",
StyleDefinitions->"Reference.nb"
]
