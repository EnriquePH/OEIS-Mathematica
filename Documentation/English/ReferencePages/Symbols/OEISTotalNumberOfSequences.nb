Notebook[{
Cell["OEISTotalNumberOfSequences", "ObjectName"],

Cell["\<\
OEISTotalNumberOfSequences[] returns an estimate of the number of sequences \
OEIS currently contains, by checking that OEIS can be reached.\
\>", "Usage"],

Cell["Options", "Subsubsection"],

Cell["URL -> True", "Text"],

