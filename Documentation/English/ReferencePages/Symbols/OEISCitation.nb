Notebook[{
Cell["OEISCitation", "ObjectName"],

Cell["\<\
OEISCitation[id,format] returns a citation string for id in the given format, \
\"BibTeX\" or \"Wiki\", without writing to a file. OEISExport's \
\".bib\"/\".wiki\" output is built from this.\
\>", "Usage"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection"],

Cell["OEISCitation[\"A000045\", \"Wiki\"]", "Input"],

Cell["\<\
\"* {{oeis|A000045}}: Fibonacci numbers: F(n) = F(n-1) + F(n-2) with F(0) = 0 \
and F(1) = 1.\"\
\>", "Output"]
}, Open  ]],

Cell["See Also", "SeeAlsoSection"],

Cell["OEISExport  \[FilledSmallSquare]  OEISImport", "SeeAlso"]
},
WindowTitle->"OEISCitation",
TaggingRules->Association["Paclet" -> "OEIS"],
FrontEndVersion->"11.2 for Linux x86 (64-bit) (September 10, 2017)",
StyleDefinitions->"Reference.nb"
]
