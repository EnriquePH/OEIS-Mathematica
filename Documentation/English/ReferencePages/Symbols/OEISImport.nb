(* Beginning of Notebook Content *)
Notebook[{
Cell["OEISImport", "ObjectName"],

Cell["\<\
OEISImport[id,element] retrieves the requested piece of data for an OEIS \
sequence from the official JSON API. element can be \"Data\", \
\"Description\", \"Author\", \"Date\", \"Offset\"/\"MinData\", \"MaxData\" or \
\"bFile\".\
\>", "Usage"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection"],

Cell["OEISImport[\"A000045\", \"Description\"]", "Input"],

Cell["\<\
\"Fibonacci numbers: F(n) = F(n-1) + F(n-2) with F(0) = 0 and F(1) = 1.\"\
\>", "Output"],

Cell["OEISImport[\"A000045\", \"Data\"]", "Input"],

Cell["\<\
{{0, 0}, {1, 1}, {2, 1}, {3, 2}, {4, 3}, {5, 5}, {6, 8}, {7, 13}, {8, 21}, \
{9, 34}, {10, 55}, {11, 89}} (* ... 41 terms total *)\
\>", "Output"],

Cell["OEISImport[\"A000045\", \"MinData\"]", "Input"],

Cell["0", "Output"],

Cell["OEISImport[\"A000045\", \"Author\"]", "Input"],

Cell["{\"_N. J. A. Sloane_, 1964\"}", "Output"]
}, Open  ]],

Cell["See Also", "SeeAlsoSection"],

Cell["\<\
OEISFunction  \[FilledSmallSquare]  OEISExport  \[FilledSmallSquare]  \
OEISbFile  \[FilledSmallSquare]  OEISValidateIDQ\
\>", "SeeAlso"]
},
WindowTitle->"OEISImport",
TaggingRules->Association["Paclet" -> "OEIS"],
FrontEndVersion->"11.2 for Linux x86 (64-bit) (September 10, 2017)",
StyleDefinitions->"Reference.nb"
]
