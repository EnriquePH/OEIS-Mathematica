Notebook[{
Cell["OEISRelated", "ObjectName"],

Cell["\<\
OEISRelated[id] returns the IDs of sequences OEIS cross-references from id's \
entry (its \"Cf. A000032, ...\" comments).\
\>", "Usage"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection"],

Cell["OEISRelated[\"A000045\"][[1 ;; 5]]", "Input"],

Cell["{\"A001622\", \"A039834\", \"A001519\", \"A001906\", \"A001690\"}", \
"Output"]
}, Open  ]],

Cell["See Also", "SeeAlsoSection"],

Cell["OEISGraph  \[FilledSmallSquare]  OEISImport", "SeeAlso"]
},
