(* Beginning of Notebook Content *)
Notebook[{
Cell["OEISValidateIDQ", "ObjectName"],

Cell["\<\
OEISValidateIDQ[id] checks that id has the canonical OEIS shape \"A\" \
followed by 6 digits, such as \"A000045\". OEISValidateIDQ[{id1,id2,...}] \
checks every id in the list.\
\>", "Usage"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection"],

Cell["OEISValidateIDQ[\"A000045\"]", "Input"],

Cell["True", "Output"],

Cell["OEISValidateIDQ[{\"A000045\", \"A000040\"}]", "Input"],

Cell["True", "Output"],

Cell["Quiet[OEISValidateIDQ[\"not-an-id\"]]", "Input"],

Cell["False", "Output"]
}, Open  ]],

Cell["See Also", "SeeAlsoSection"],

Cell["OEISImport  \[FilledSmallSquare]  OEISURL  \[FilledSmallSquare]  \
OEISFunction", "SeeAlso"]
},
