Notebook[{
Cell["OEISGraph", "ObjectName"],

Cell["\<\
OEISGraph[id] returns a Graph of id and the sequences OEISRelated finds for \
it, star-shaped around id.\
\>", "Usage"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection"],

Cell["g = OEISGraph[\"A000045\"]; {VertexCount[g], EdgeCount[g]}", "Input"],

Cell["{90, 89}", "Output"]
}, Open  ]],

