(* Beginning of Notebook Content *)
Notebook[{
Cell["OEISExport", "ObjectName"],

Cell["\<\
OEISExport[id,filename] exports OEIS content for id to filename, in a format \
chosen from the file extension: \".m\"/\".gp\" (usage message code), \
\".txt\"/\".csv\"/\".tsv\"/\".dat\" (data), image formats, \".bib\" (BibTeX \
citation), \".html\" and \".wiki\" (MediaWiki citation).\
\>", "Usage"],

Cell["Basic Examples", "ExampleSection"],

Cell["See Also", "SeeAlsoSection"],

Cell["OEISImport  \[FilledSmallSquare]  OEISbFile", "SeeAlso"]
},
WindowTitle->"OEISExport",
TaggingRules->Association["Paclet" -> "OEIS"],
FrontEndVersion->"11.2 for Linux x86 (64-bit) (September 10, 2017)",
StyleDefinitions->"Reference.nb"
]
