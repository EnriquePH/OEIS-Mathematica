(* Beginning of Notebook Content *)
Notebook[{
Cell["OEISbFile", "ObjectName"],

Cell["\<\
OEISbFile[id,VMax,filename] writes a b-file with the values of id(n) for n \
from the sequence offset up to VMax. If id[n_]:=... is already defined in the \
session, that definition is used to compute every term up to VMax; otherwise \
the data already published on OEIS is used instead.\
\>", "Usage"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection"],

Cell["\<\
A358061[n_] := Mod[EulerPhi[n], DivisorSigma[0, n]]; OEISbFile[\"A358061\", \
20, FileNameJoin[{$TemporaryDirectory, \"b358061_doc_example.txt\"}]]; \
ReadList[FileNameJoin[{$TemporaryDirectory, \"b358061_doc_example.txt\"}], \
String]\
\>", "Input"],

Cell["\<\
{\"1 0\", \"2 1\", \"3 0\", \"4 2\", \"5 0\", \"6 2\", \"7 0\", \"8 0\", \"9 \
0\", \"10 0\", \"11 0\", \"12 4\"} (* ... 20 terms total *)\
\>", "Output"]
}, Open  ]],

Cell["See Also", "SeeAlsoSection"],

Cell["OEISFunction  \[FilledSmallSquare]  OEISImport  \[FilledSmallSquare]  \
OEISURL", "SeeAlso"]
},
WindowTitle->"OEISbFile",
TaggingRules->Association["Paclet" -> "OEIS"],
FrontEndVersion->"11.2 for Linux x86 (64-bit) (September 10, 2017)",
StyleDefinitions->"Reference.nb"
]
