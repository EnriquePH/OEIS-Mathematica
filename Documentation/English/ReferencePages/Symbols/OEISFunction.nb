Notebook[{
Cell["OEISFunction", "ObjectName"],

Cell["\<\
OEISFunction[id] defines id[n] in the current session, preloaded with the \
data available from OEIS, and adds a usage message built from the sequence \
description.\
\>", "Usage"],

Cell["Options", "Subsubsection"],

Cell["\<\
AddHelp -> True
bFile -> True
Output -> True\
\>", "Text"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection"],

Cell["OEISFunction[\"A000045\", Output -> False]; A000045[10]", "Input"],

Cell["55", "Output"]
}, Open  ]],

Cell["See Also", "SeeAlsoSection"],

Cell["OEISImport  \[FilledSmallSquare]  OEISbFile", "SeeAlso"]
},
