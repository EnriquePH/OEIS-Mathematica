(* Beginning of Notebook Content *)
Notebook[{
Cell["OEIS Package: A Tutorial", "Title"],

Cell["\<\
Every example on this page was executed live against the real OEIS JSON API \
-- the output shown is real, not illustrative. The runnable, plain-script \
version of this tutorial is test/OEISTutorial.wl.\
\>", "Text"],

Cell["Load the package", "Section"],

Cell["\<\
Loading the package puts every OEISXXX function on $ContextPath.\
\>", "Text"],

Cell["Needs[\"OEIS`\"]", "Input"],

Cell["Null", "Output"],

Cell["Validate an identifier and build its URLs", "Section"],

Cell["OEISValidateIDQ[\"A000045\"]", "Input"],

Cell["True", "Output"],

Cell["OEISURL[\"A000045\"]", "Input"],

Cell["\"https://oeis.org/A000045\"", "Output"],

Cell["OEISURL[\"A000045\", bFile -> True]", "Input"],

Cell["\"https://oeis.org/b000045.txt\"", "Output"],

Cell["Retrieve sequence data", "Section"],

Cell["\<\
OEISImport talks to the live OEIS JSON API for \"Description\", \"Data\", \
\"Author\", \"Date\", \"MinData\"/\"Offset\" and \"MaxData\".\
\>", "Text"],

Cell["OEISImport[\"A000045\", \"Description\"]", "Input"],

Cell["\<\
\"Fibonacci numbers: F(n) = F(n-1) + F(n-2) with F(0) = 0 and F(1) = 1.\"\
\>", "Output"],

Cell["OEISImport[\"A000045\", \"Data\"][[1 ;; 10]]", "Input"],

Cell["\<\
{{0, 0}, {1, 1}, {2, 1}, {3, 2}, {4, 3}, {5, 5}, {6, 8}, {7, 13}, {8, 21}, \
{9, 34}}\
\>", "Output"],

Cell["\<\
{OEISImport[\"A000045\", \"MinData\"], OEISImport[\"A000045\", \"MaxData\"]}\
\>", "Input"],

Cell["{0, 40}", "Output"],

Cell["Materialize a sequence as a function", "Section"],

Cell["\<\
OEISFunction defines id[n] in this session, preloaded with the data OEIS \
already has.\
\>", "Text"],

Cell["OEISFunction[\"A000045\", Output -> False]; A000045[20]", "Input"],

Cell["6765", "Output"],

Cell["Generate a b-file from your own formula", "Section"],

Cell["\<\
If id[n_] := ... is already defined -- as documented on the OEIS wiki page \
for this package -- OEISbFile uses that definition to compute every term up \
to VMax, even far beyond what OEIS has published. A358061 only has about 90 \
published terms; this still produces all 2000 requested, computed locally \
with EulerPhi and DivisorSigma.\
\>", "Text"],

Cell["\<\
A358061[n_] := Mod[EulerPhi[n], DivisorSigma[0, n]]; OEISbFile[\"A358061\", \
2000, FileNameJoin[{$TemporaryDirectory, \"b358061_tutorial.txt\"}]]; \
Length[ReadList[FileNameJoin[{$TemporaryDirectory, \
\"b358061_tutorial.txt\"}], String]]\
\>", "Input"],

Cell["2000", "Output"],

Cell["Generate a b-file straight from OEIS data", "Section"],

Cell["\<\
Without a local definition, OEISbFile falls back to whatever OEIS already has \
published for that ID.\
\>", "Text"],

Cell["\<\
ClearAll[A358061]; OEISbFile[\"A000045\", 15, \
FileNameJoin[{$TemporaryDirectory, \"b000045_tutorial.txt\"}]]; \
ReadList[FileNameJoin[{$TemporaryDirectory, \"b000045_tutorial.txt\"}], \
String]\
\>", "Input"],

Cell["\<\
{\"0 0\", \"1 1\", \"2 1\", \"3 2\", \"4 3\", \"5 5\", \"6 8\", \"7 13\", \"8 \
21\", \"9 34\", \"10 55\", \"11 89\"} (* ... 16 terms total *)\
\>", "Output"],

Cell["See Also", "Section"],

Cell["\<\
The OEIS Package guide page lists every function with a one-line description.\
\
\>", "Text"]
},
WindowTitle->"OEIS Package: A Tutorial",
FrontEndVersion->"11.2 for Linux x86 (64-bit) (September 10, 2017)",
StyleDefinitions->"Tutorial.nb"
]
(* End of Notebook Content *)

